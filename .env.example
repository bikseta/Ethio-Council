# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=ethio_council
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password

# ── Security ──────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_generate_a_strong_secret_key

# ── CORS ──────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Email ─────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@ecfe.et
SMTP_PASSWORD=change_me
FRONTEND_URL=http://localhost:3000

# ── Mapbox ────────────────────────────────────────────────────
REACT_APP_MAPBOX_TOKEN=your_mapbox_token_here

# ── Service URLs (frontend) ───────────────────────────────────
REACT_APP_CORE_API_URL=http://localhost:8001
REACT_APP_GIS_API_URL=http://localhost:8002
REACT_APP_ANALYTICS_API_URL=http://localhost:8003
REACT_APP_CRISIS_API_URL=http://localhost:8004

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
