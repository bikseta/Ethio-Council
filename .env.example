# Database
DATABASE_URL=postgresql://ecfe_user:ecfe_pass@db:5432/ecfe_db
POSTGRES_USER=ecfe_user
POSTGRES_PASSWORD=ecfe_pass
POSTGRES_DB=ecfe_db

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS / LocalStack
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=http://localstack:4566
S3_BUCKET_NAME=ecfe-documents

# Frontend
REACT_APP_CORE_API_URL=http://localhost:8000
REACT_APP_GIS_API_URL=http://localhost:8001
REACT_APP_CRISIS_API_URL=http://localhost:8002
REACT_APP_ANALYTICS_API_URL=http://localhost:8003
REACT_APP_MAPBOX_TOKEN=your-mapbox-token-here

# Mapbox
MAPBOX_TOKEN=your-mapbox-token-here
